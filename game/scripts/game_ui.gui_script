-- /game/game_ui.gui_script

-- Максимальная ширина цветной полоски (должна совпадать с шириной bar_bg в GUI)
local MAX_BAR_WIDTH = 100 

-- function init(self)
-- 	msg.post(".", "acquire_input_focus")
-- 
